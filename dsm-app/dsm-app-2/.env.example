# ─── Client-side (Vite — bundled into the browser) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# DEV ONLY — direct browser → Anthropic for local testing without `vercel dev`.
# DO NOT set this in production. The Vercel function holds the real key server-side.
VITE_ANTHROPIC_API_KEY=

# ─── Server-side only (Vercel functions) ───
# Set these in Vercel → Settings → Environment Variables. Never commit.
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
