# ─── Client-side (Vite — bundled into the browser) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=

# DEV ONLY — direct browser → Anthropic for local testing without `vercel dev`.
# DO NOT set this in production. The Vercel function holds the real key server-side.
VITE_ANTHROPIC_API_KEY=

# ─── Server-side only (Vercel function / api/coach.js) ───
# Set this in your Vercel project dashboard → Settings → Environment Variables.
# Never commit. Never expose to the client.
ANTHROPIC_API_KEY=
